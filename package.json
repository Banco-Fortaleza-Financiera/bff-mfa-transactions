{
  "name": "bff-mfa-transactions",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --configuration local",
    "start:local": "ng serve --configuration local",
    "start:dev": "ng serve --configuration dev",
    "start:test": "ng serve --configuration test",
    "start:prod": "ng serve --configuration production",
    "start:app": "ng serve --configuration local",
    "start:mf": "npm run start:mf:local",
    "start:mf:local": "webpack serve --env configuration=local --mode development",
    "start:mf:dev": "webpack serve --env configuration=dev --mode development",
    "start:mf:test": "webpack serve --env configuration=test --mode development",
    "start:mf:prod": "webpack serve --env configuration=production --mode production",
    "build": "ng build --configuration local",
    "build:local": "ng build --configuration local",
    "build:dev": "ng build --configuration dev",
    "build:test": "ng build --configuration test",
    "build:prod": "ng build --configuration production",
    "build:mf": "npm run build:mf:prod",
    "build:mf:local": "ng build --configuration local && webpack --config webpack.config.js --env configuration=local --mode development",
    "build:mf:dev": "ng build --configuration dev && webpack --config webpack.config.js --env configuration=dev --mode development",
    "build:mf:test": "ng build --configuration test && webpack --config webpack.prod.config.js --env configuration=test --mode production",
    "build:mf:prod": "ng build --configuration production && webpack --config webpack.prod.config.js --env configuration=production --mode production",
    "watch": "ng build --watch --configuration local",
    "watch:local": "ng build --watch --configuration local",
    "watch:dev": "ng build --watch --configuration dev",
    "watch:test": "ng build --watch --configuration test",
    "generate:project": "powershell -ExecutionPolicy Bypass -File scripts/replicate-project.ps1",
    "replicate": "npm run generate:project --",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --runInBand",
    "test:ci:coverage": "jest --ci --runInBand --coverage",
    "test:coverage": "jest --coverage",
    "prepare": "husky"
  },
  "private": true,
  "packageManager": "npm@11.5.1",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular-architects/module-federation": "^21.2.2",
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.0",
    "@types/jest": "^30.0.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-preset-angular": "^16.1.4",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "ts-loader": "^9.5.7",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  }
}
